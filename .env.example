# ================================
# TaxBot Configuration
# ================================

# Helius API Key (required — for full parsed transaction history)
# Get free key at: https://helius.dev
HELIUS_API_KEY=your_helius_key_here

# Birdeye API Key (optional — for historical prices at exact tx timestamps)
# Without this, TaxBot falls back to CoinGecko public API
BIRDEYE_API_KEY=

# ================================
# Tax Settings
# ================================

# Cost basis method: fifo, lifo, hifo
COST_BASIS_METHOD=fifo

# Currency for all reports
BASE_CURRENCY=USD

# Fiscal year start month (1=January, 4=April for UK, 7=July for Australia)
TAX_YEAR_START_MONTH=1

# ================================
# Thresholds
# ================================

# Ignore transactions with proceeds below this USD amount (de minimis rule)
# Set to 0 to include all transactions
DE_MINIMIS_USD=0

# ================================
# Cache Settings
# ================================

# Cache transaction history locally to avoid re-fetching
USE_CACHE=true
CACHE_DB=taxbot_cache.db

# ================================
# Logging
# ================================
LOG_LEVEL=INFO
